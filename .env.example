# =============================================================================
# Padrão: deploy em produção (Docker na VPS, rede raphael-bridge, ver LLM.md)
# Ajuste segredos reais no servidor; nunca commitar o .env com chaves preenchidas.
#
# Desenvolvimento local: copie para .env e SOBRESCREVA com os valores descritos
# nos comentários "Local (hub.test) / máquina e Docker de infra". O .env da máquina
# de dev NÃO segue estes padrões de produção (APP_DEBUG, APP_URL, DB_HOST, etc.).
# =============================================================================

APP_NAME=RaphaelPersonalHub
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
# Produção: URL pública da API (Cloudflare + Nginx do host)
# Local (hub.test, nginx + PHP no host, Postgres/Redis/Mailpit no Docker de infra):
#   APP_URL=http://hub.test
#   (ou https://hub.test se o vhost local tiver SSL; alinhar com o que o browser abre)
# Local (só o docker compose deste repositório, sem vhost):
#   APP_URL=http://localhost:8082
# Evolution API (webhook): em dev use URL pública — ex. cloudflared/quick tunnel apontando para
#   esta app (porta do php artisan serve ou nginx local). Produção não alcança hub.test nem localhost.
#   Webhook Laravel: POST `/webhook/whatsapp`. APP_URL deve ser
#   coerente com URLs geradas pelo Laravel se algo assinar links; o POST do webhook usa o host que você configurar.
APP_URL=https://api.raphael-martins.com
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

PUID=1003
PGID=1003

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# Produção: error | warning. Local: debug
LOG_LEVEL=error

# ---------------------------------------------------------------------------
# Banco — PostgreSQL 17 (Hub usa SOMENTE pgsql; MySQL no mesmo host/compose = outro app)
# Produção: serviço na rede Docker (nome do container)
# Local (hub.test, Postgres do compose de infra com porta publicada no host):
#   DB_HOST=127.0.0.1
#   DB_PORT=5432  (ou a porta mapeada, ex. 5433)
# Local (PHP em container compartilhando rede com o Postgres de dev):
#   DB_HOST=nome_do_serviço_postgres
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=raphael-postgres
DB_PORT=5432
DB_DATABASE=raphael
DB_USERNAME=raphael_app
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Redis 7
# Produção: raphael-redis
# Local (porta publicada no host): REDIS_HOST=127.0.0.1
# ---------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=raphael-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Session / Cache / Queue
# Produção: redis + filas reais. Local rápido: QUEUE_CONNECTION=sync
# Local (hub.test com workers): QUEUE_CONNECTION=redis e rodar horizon/queue:work
# ---------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
# Produção (HTTPS): true. Local: false
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=raphael:

# MinIO
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ---------------------------------------------------------------------------
# MinIO S3
# Preencher com credenciais do ambiente alvo (não duplicar segredos reais neste arquivo no git)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=raphael-hub
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=http://raphael-minio:9000/raphael-hub

# ---------------------------------------------------------------------------
# Evolution DB
# ---------------------------------------------------------------------------
EVOLUTION_POSTGRES_DB=evolution
EVOLUTION_POSTGRES_USER=evolution
EVOLUTION_POSTGRES_PASSWORD=coloque_outra_senha_forte

# ---------------------------------------------------------------------------
# Evolution API
# ---------------------------------------------------------------------------
EVOLUTION_SERVER_URL=https://evo.raphael-martins.com
EVOLUTION_API_KEY=coloque_api_key_forte
EVOLUTION_WEBHOOK_GLOBAL_URL=https://api.raphael-martins.com/webhook/whatsapp
EVOLUTION_WEBHOOK_GLOBAL_ENABLED=true
EVOLUTION_WEBHOOK_EVENTS_MESSAGES_UPSERT=true
EVOLUTION_WEBHOOK_EVENTS_SEND_MESSAGE=true
EVOLUTION_LOG_LEVEL=ERROR

# ---------------------------------------------------------------------------
# Evolution S3
# ---------------------------------------------------------------------------
EVOLUTION_S3_BUCKET=raphael-evolution

# ---------------------------------------------------------------------------
# Evolution API — instância raphael
# ---------------------------------------------------------------------------
EVOLUTION_URL=https://evo.raphael-martins.com
EVOLUTION_INSTANCE=raphael
# Deve coincidir com o campo JSON `apikey` que a Evolution manda no body do webhook (e/ou header apikey).
EVOLUTION_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# WhatsApp — grupo da casa (notificações); JID terminando em @g.us
# ---------------------------------------------------------------------------
WHATSAPP_GRUPO_CASA_JID=

# Grupo “só você” para notas/mídia — roteamento usa ProcessPersonalWhatsAppMessage (workaround Evolution).
WHATSAPP_NOTAS_GRUPO_JID=120363424213917118@g.us
WHATSAPP_NOTAS_GRUPO_LABEL="Raphael Martins"

# ---------------------------------------------------------------------------
# Horizon — produção: HTTPS + domínio da API; definir emails autorizados
# ---------------------------------------------------------------------------
HORIZON_NAME="Raphael Hub"
HORIZON_DOMAIN=null
HORIZON_PATH=horizon
HORIZON_PREFIX=raphael_horizon:
# Produção: restrito (IPs da VPS / escritório se necessário)
HORIZON_AUTH_IPS=
HORIZON_AUTH_EMAILS=

# Web (Breeze): usuários são criados manualmente/seeder — sem registro público.
# Coluna users.global_role: super_admin | member; escopo por grupo: monitored_source_user — docs/v2.md
#
# Seed local (SuperAdminUserSeeder): obrigatório definir senha no .env local — nunca commitar.
HUB_SEED_SUPER_ADMIN_NAME="Raphael Martins"
HUB_SEED_SUPER_ADMIN_EMAIL=rapha@raphael-martins.com
HUB_SEED_SUPER_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# NeuronAI — providers
# ---------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_URL=https://api.groq.com/openai/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

AI_PRIMARY_PROVIDER=groq
AI_FALLBACK_PROVIDER=anthropic

# ---------------------------------------------------------------------------
# CapSolver — reCAPTCHA Coelba/Neoenergia
# ---------------------------------------------------------------------------
CAPSOLVER_API_KEY=

# ---------------------------------------------------------------------------
# Scraping — só no .env da máquina que roda scraping (nunca no banco)
# ---------------------------------------------------------------------------
EMBASA_CPF=
EMBASA_PASSWORD=
EMBASA_MATRICULA=

COELBA_CPF=
COELBA_PASSWORD=
COELBA_CODIGO_CLIENTE=

# ---------------------------------------------------------------------------
# Mail — produção: configurar SMTP real ou provider (SES, Mailgun, etc.)
# Local (Mailpit): MAIL_MAILER=smtp, MAIL_HOST=127.0.0.1, MAIL_PORT=1025,
#   MAIL_ENCRYPTION=null. UI do Mailpit costuma ser http://localhost:8025 (porta do compose).
# Se o PHP estiver em container sem acesso a 127.0.0.1 do host, use o hostname do Mailpit na rede Docker.
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@raphael-martins.com
MAIL_FROM_NAME="${APP_NAME}"
